# Copy and edit this file if you need a named launch config.
# Submit with:
#   bash scripts/submit_housebuild_collm_cc_slurm_job.sh configs/cluster/house_build_collm_cc_3gpu.env

SLURM_JOB_NAME=hb-collm-cc-3gpu
SLURM_ACCOUNT=gzmcagent
SLURM_PARTITION=normal
SLURM_NODES=1
SLURM_GPUS_PER_NODE=3
SLURM_NTASKS_PER_NODE=1
SLURM_CPUS_PER_TASK=40
SLURM_TIME=48:00:00
SLURM_OUTPUT=slurm-%x-%j.out
SLURM_ERROR=slurm-%x-%j.err
SLURM_EXCLUDE=

CONDA_ENV=llm-collab-mc
MODULES=Anaconda3

AGENT_MODEL=Qwen/Qwen3-4B-Instruct-2507
CRITIC_MODEL=Qwen/Qwen3-4B-Instruct-2507
DTYPE=bf16
TRAIN_SPLIT='[:8]'
EVAL_SPLIT='[8:]'
SEED=42
NUM_EPOCHS=150
NUM_TURNS=4
NUM_GENERATIONS=1
MAX_NEW_TOKENS=512
AGENT_LEARNING_RATE=5e-6
CRITIC_LEARNING_RATE=5e-6
VALUE_LOSS_COEF=0.6
ROLLOUT_BUFFER_SIZE=1
TRAIN_BATCH_SIZE=1
EVAL_INTERVAL=10
EVAL_NUM_SAMPLES=2
EVAL_BATCH_SIZE=1
SAVE_FINAL_MODEL=true
RUN_PREFLIGHT=true

WANDB_PROJECT=house_build
WANDB_ENTITY=
WANDB_MODE=online
WANDB_TAGS=collm-cc,maac,house_build,slurm,3gpu,h800,qwen3-4b
