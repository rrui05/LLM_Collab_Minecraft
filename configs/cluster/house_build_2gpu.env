# Copy and edit this file if you need a named launch config.
# Submit with:
#   bash scripts/submit_housebuild_slurm_job.sh configs/cluster/house_build_2gpu.env

SLURM_JOB_NAME=hb-magrpo-2gpu
SLURM_ACCOUNT=gzmcagent
SLURM_PARTITION=normal
SLURM_NODES=1
SLURM_GPUS_PER_NODE=2
SLURM_NTASKS_PER_NODE=1
SLURM_CPUS_PER_TASK=32
SLURM_TIME=30:00:00
SLURM_OUTPUT=slurm-%x-%j.out
SLURM_ERROR=slurm-%x-%j.err
SLURM_EXCLUDE=

CONDA_ENV=llm-collab-mc
MODULES=Anaconda3

AGENT_MODEL=Qwen/Qwen3-4B-Instruct-2507
DTYPE=bf16
TRAIN_SPLIT='[:8]'
EVAL_SPLIT='[8:]'
SEED=42
NUM_EPOCHS=20
NUM_TURNS=4
NUM_GENERATIONS=2
MAX_NEW_TOKENS=512
LEARNING_RATE=1e-5
ROLLOUT_BUFFER_SIZE=1
TRAIN_BATCH_SIZE=1
EVAL_INTERVAL=2
EVAL_NUM_SAMPLES=2
EVAL_BATCH_SIZE=1
SAVE_FINAL_MODEL=true

WANDB_PROJECT=house_build
WANDB_ENTITY=
WANDB_MODE=online
WANDB_TAGS=magrpo,house_build,slurm,2gpu,h800
